{
  "name": "ticket-operator-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/api",
    "dev:api": "npm run dev -w apps/api",
    "dev:admin": "npm run dev -w apps/admin",
    "build": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/admin",
    "lint": "npm run lint -ws",
    "start": "npm run start -w apps/api"
  }
}
